# HydraDB
HYDRADB_API_KEY=your_hydradb_api_key_here
HYDRADB_ENDPOINT=https://your-instance.hydradb.io

# OpenAI — set a hard $5 spend cap in the console before using
OPENAI_API_KEY=your_openai_api_key_here

# GitHub — needs repo:read and read:org scopes
GITHUB_TOKEN=your_github_pat_here

# Slack (optional — skip if low on time)
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
WS_PORT=8765

# Demo repo (default target for ingestion)
DEMO_REPO=tokio-rs/tokio
