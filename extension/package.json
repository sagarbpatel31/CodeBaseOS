{
  "name": "codebaseos",
  "displayName": "CodebaseOS",
  "description": "Right-click any line. Ask why. Get the real answer.",
  "version": "0.4.1",
  "publisher": "CodeBaseOS",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "keywords": ["provenance", "history", "why", "graph", "HydraDB"],
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/sagarbpatel31/CodeBaseOS.git"
  },
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codebaseos.why",
        "title": "CodebaseOS: Why is this here?"
      },
      {
        "command": "codebaseos.compare",
        "title": "CodebaseOS: Compare (with vs without HydraDB)"
      },
      {
        "command": "codebaseos.provenance",
        "title": "CodebaseOS: Origin story (provenance chain)"
      },
      {
        "command": "codebaseos.ingestRepo",
        "title": "CodebaseOS: Ingest this repo"
      },
      {
        "command": "codebaseos.busFactor",
        "title": "CodebaseOS: Bus factor (knowledge risk)"
      },
      {
        "command": "codebaseos.explainFile",
        "title": "CodebaseOS: Explain this file"
      },
      {
        "command": "codebaseos.diff",
        "title": "CodebaseOS: What changed (time window)"
      },
      {
        "command": "codebaseos.ask",
        "title": "CodebaseOS: Ask the codebase"
      },
      {
        "command": "codebaseos.risk",
        "title": "CodebaseOS: Knowledge-risk files"
      },
      {
        "command": "codebaseos.auditReport",
        "title": "CodebaseOS: Provenance report"
      },
      {
        "command": "codebaseos.fiveWhys",
        "title": "CodebaseOS: Five Whys"
      },
      {
        "command": "codebaseos.counterfactual",
        "title": "CodebaseOS: Counterfactual"
      },
      {
        "command": "codebaseos.handoff",
        "title": "CodebaseOS: Generate onboarding tour for current module"
      },
      {
        "command": "codebaseos.openDashboard",
        "title": "CodebaseOS: Open Dashboard"
      }
    ],
    "configuration": {
      "title": "CodebaseOS",
      "properties": {
        "codebaseos.backendUrl": {
          "type": "string",
          "default": "http://localhost:8000",
          "description": "URL of the CodebaseOS backend API."
        },
        "codebaseos.dashboardUrl": {
          "type": "string",
          "default": "http://localhost:3000",
          "description": "URL of the CodebaseOS dashboard (opened on status bar click)."
        },
        "codebaseos.enableCodeLens": {
          "type": "boolean",
          "default": true,
          "description": "Show '🧬 Why?' code lens above function definitions"
        },
        "codebaseos.repo": {
          "type": "string",
          "default": "",
          "description": "Repository (owner/name) to scope provenance queries, e.g. tokio-rs/tokio. Leave empty to search across all ingested repos."
        }
      }
    },
    "menus": {
      "editor/context": [
        {
          "command": "codebaseos.why",
          "group": "navigation"
        },
        {
          "command": "codebaseos.compare",
          "group": "navigation"
        },
        {
          "command": "codebaseos.provenance",
          "group": "navigation"
        }
      ]
    },
    "walkthroughs": [
      {
        "id": "codebaseos.getStarted",
        "title": "Get started with CodebaseOS",
        "description": "Provenance for any repo, in three steps.",
        "steps": [
          {
            "id": "backend",
            "title": "Start the backend",
            "description": "CodebaseOS talks to a local backend.\n[Open dashboard](command:codebaseos.openDashboard)",
            "media": { "markdown": "media/walkthrough/backend.md" }
          },
          {
            "id": "ingest",
            "title": "Ingest this repo",
            "description": "Pull this repo's history into the graph — auto-detected from your git remote.\n[Ingest this repo](command:codebaseos.ingestRepo)",
            "media": { "markdown": "media/walkthrough/ingest.md" },
            "completionEvents": ["onCommand:codebaseos.ingestRepo"]
          },
          {
            "id": "why",
            "title": "Ask why",
            "description": "Hover a line or use the CodeLens to ask why code exists.\n[Why is this here?](command:codebaseos.why)",
            "media": { "markdown": "media/walkthrough/why.md" },
            "completionEvents": ["onCommand:codebaseos.why"]
          },
          {
            "id": "explore",
            "title": "Explore provenance",
            "description": "Origin story, compare, five whys, bus factor.\n[Open dashboard](command:codebaseos.openDashboard)",
            "media": { "markdown": "media/walkthrough/explore.md" }
          }
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "pretest": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "18.x",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "@vscode/vsce": "^2.26.0",
    "typescript": "^5.4.0"
  }
}
